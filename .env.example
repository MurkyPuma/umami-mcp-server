# Copy to .env and fill in. Loaded automatically when you run the server locally.

# Your Umami base URL (Umami Cloud or self-hosted), no trailing path.
UMAMI_API_URL=https://cloud.umami.is

# --- Authentication: choose ONE of the two options below ---

# Option A: API key (Umami Cloud, or newer self-hosted). Sent as x-umami-api-key.
# UMAMI_API_KEY=your-api-key

# Option B: username + password (exchanged for a bearer token via /api/auth/login).
# UMAMI_USERNAME=your-username
# UMAMI_PASSWORD=your-password

# Optional: team id. If set, get_websites lists the team's websites; otherwise yours.
# UMAMI_TEAM_ID=your-team-id

# Optional: per-request timeout in seconds (default 30).
# UMAMI_TIMEOUT=30
